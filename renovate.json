{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekends",
    ":dependencyDashboard",
    ":automergeMinor",
    "group:allNonMajor"
  ],
  "major": {
    "dependencyDashboardApproval": true
  },
  "lockFileMaintenance": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchManagers": [
        "composer"
      ],
      "rangeStrategy": "update-lockfile"
    }
  ]
}
